{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dawnland Launcher",
  "version": "0.1.0",
  "identifier": "com.dawnland.launcher",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Dawnland Launcher",
        "width": 1024,
        "height": 700,
        "minWidth": 1024,
        "minHeight": 700,
        "maxWidth": 1024,
        "maxHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
