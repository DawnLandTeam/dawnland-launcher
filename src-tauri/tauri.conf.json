{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DLML",
  "version": "0.0.1",
  "identifier": "com.dawnland.launcher",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Dawnland Launcher",
        "width": 1024,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "maxWidth": 1200,
        "maxHeight": 800,
        "resizable": false,
        "fullscreen": false,
        "maximizable": false,
        "decorations": false,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**/.mod_cache/**/*"],
          "requireLiteralLeadingDot": false
        }
      },
      "csp": "default-src 'self' tauri:; connect-src 'self' https://* http://localhost:* ws://localhost:* wss://*; img-src 'self' asset: https://* data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval' 'unsafe-inline'; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "appimage"
    ],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["dlml"]
      }
    }
  }
}